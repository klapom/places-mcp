# Google Places & Routes MCP - API key from Google Maps Platform
# Enable: Places API (New) + Routes API in Google Cloud Console

GOOGLE_PLACES_API_KEY=your_google_maps_api_key

# Rate limiting
MAX_REQUESTS_PER_HOUR=60
MAX_REQUESTS_PER_MONTH=5000

# Optional: Default location bias (your home location)
# If set, searches without explicit coordinates will be biased to this area
# DEFAULT_LAT=48.1351
# DEFAULT_LNG=11.5820
