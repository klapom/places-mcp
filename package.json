{
  "name": "places-mcp",
  "version": "0.4.0",
  "description": "MCP server for Google Places (New) API + Routes + Route-Weather",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "places-mcp": "dist/index.js"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": ["mcp", "google", "places", "maps"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch --env-file=.env src/http_server.ts",
    "start": "node --env-file=.env dist/http_server.js",
    "start:stdio": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit",
    "mcp:inspect": "pnpm dlx @modelcontextprotocol/inspector node --env-file=.env dist/index.js"
  },
  "dependencies": {
    "@klapom/mcp-toolkit-ts": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^22.12.0",
    "@vitest/coverage-v8": "^3.0.0",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "license": "UNLICENSED",
  "private": true
}
